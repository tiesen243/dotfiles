layout {
  focus-ring {
    active-gradient from="{{colors.primary.default.hex}}" to="{{colors.tertiary.default.hex}}" angle=45
    inactive-color "{{colors.on_tertiary.default.hex}}"
  }

  border {
    active-gradient from="{{colors.primary.default.hex}}" to="{{colors.tertiary.default.hex}}" angle=45
    inactive-color "{{colors.on_tertiary.default.hex}}"
  }

  shadow {
    color "{{colors.shadow.default.hex}}"
  }
}
