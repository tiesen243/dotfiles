{
  "$schema": "https://raw.githubusercontent.com/LuaLS/vscode-lua/master/setting/schema.json",
  "runtime": {
    "version": "LuaJIT"
  },
  "workspace": {
    "library": ["$VIMRUNTIME"]
  },
  "diagnostics": {
    "disable": ["duplicate-doc-field", "duplicate-set-field"],
    "globals": ["Snacks", "vim"]
  }
}
